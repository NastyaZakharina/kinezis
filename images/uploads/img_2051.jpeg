  top: -60px;
  background-color: transparent !important;
  font-size: 20px !important;
  width: 20% !important;
		}
}

@media only screen and (max-width: 768px) {

html[lang="en-US"] .elementor-element-9e8a6e0,
html[lang="en-US"] .elementor-element-ec4073d,
html[lang="en-US"] .elementor-element-28b5465,
