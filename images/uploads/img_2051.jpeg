    <script type="text/javascript">
        jQuery(document).ready(function($) {
            // Remove add-to-cart parameters from URLs but keep product links
            $('a[href*="add-to-cart="]').each(function() {
                var $link = $(this);
                var href = $link.attr('href');

                // If it's an add to cart button
                if ($link.hasClass('add_to_cart_button') || $link.hasClass('ajax_add_to_cart')) {
                    // Extract product ID from URL
                    var matches = href.match(/add-to-cart=(\d+)/);
                    if (matches && matches[1]) {
                        var productId = matches[1];

                        // Add data attribute if not exists
                        if (!$link.data('product_id') && !$link.data('product-id')) {
                            $link.attr('data-product_id', productId);
                        }

                        // Remove add-to-cart parameter from URL but keep the base URL
                        var cleanUrl = href.replace(/[?&]add-to-cart=\d+/, '');
                        $link.attr('href', cleanUrl);
                    }
                }
            });
        });
    </script>
    </body>
</html>
