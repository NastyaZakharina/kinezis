/* Global CSS */
body.archive.search .product-archive > .products {
		display:flex;
		flex-wrap:wrap;
}


.link-disabled {
	cursor: auto !important;
	pointer-events: none !important;
}

.link-disabled span {
	border: none !important;
}

.cpel-switcher--layout-dropdown .cpel-switcher__toggle--on + .cpel-switcher__list {
  background: #ebebeb;
}

.cpel-switcher__flag--ru img {
		filter: grayscale(100%); 
}

.thumbnail-caption {
		display: none !important;
}

.post.post-mask .post-media img {
		height: 100% !important;
		object-fit: cover;
}

#footer .elementor-social-icons-wrapper {
		display: flex;
		flex-wrap: wrap;
}

.contact-us-popup-button .contact-img-icon {
		margin-right: 13px !important;
}



.ubermenu-mobile-header nav.cpel-switcher__nav {
  display: flex !important;
	margin-left: 20px !important;
	margin-right: 20px !important;
	width: auto !important;
  align-items: center;
}

.cpel-switcher__toggle.cpel-switcher__lang {
  flex: 1;
  text-align: center;
	justify-content: flex-start !important;
  display: flex !important;
}

#ubermenu-main-144 .ubermenu-mobile-header .cpel-switcher__list {
justify-content: space-between;
  display: flex !important;
  flex-direction: row !important;
  flex: 2;
  margin: 0;
  padding: 0;
  list-style: none;
}

.cpel-switcher__list li {
  flex: 1;
  text-align: center;
}

.ubermenu-mobile-header .cpel-switcher__lang:first-child {
		display: flex !important;
  	justify-content: center;
}

.ubermenu-mobile-header .cpel-switcher__lang:last-child {
		display: flex !important;
  justify-content: flex-end;
}

.gallery-item {
  max-width: 100% !important;
}

.alignnone {
		width: auto !important;
}

.gallery-icon.landscape {
		height: 100% !important;
}

.gallery-icon.landscape img {
		object-fit: cover !important;
		height: 100% !important;
}

.home .page-content > .container {
		max-width: 100%;
}

.footer-phone strong {
		width: max-content;
  display: block;
}

.woocommerce-LoopProduct-link .woocommerce-placeholder {
		max-height: 174px;
}

.product-loop img {
		height: 230px;
		object-fit: cover;
}

@media (min-width: 992px) {
  .tab-content.tab-templates {
    margin-left: 0 !important;
  }
}

@media (max-width: 960px) {
  .elementor-2141 .elementor-element.elementor-element-63aacd5 {
    --width: 55% !important;
  }
		
		#header .e-con-inner {
				max-width: 700px;
		}
		
		.elementor-element-bc19e9e {
				display: none;
		}
}

@media (max-width: 768px) {
