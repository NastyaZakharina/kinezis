        jQuery(document).ready(function($) {
            $('#leave-request').click(function(event) {
                event.preventDefault();
                var initialText = $(this).text();
                $(this).text('Loading...');
                $('.wpb-pcf-form-fire').trigger('click');
                setTimeout(function() {
                    $('#leave-request').text(initialText);
                }, 2000);
            });
        });
    </script>
    <script type="text/javascript">
        // Проверяем, установлен ли lang="en-US" у тега html
        if (document.documentElement.lang === 'en-US') {
            // Получаем все элементы li внутри .breadcrumb_wrapper .breadcrumb
            const breadcrumbItems = document.querySelectorAll('.breadcrumb_wrapper .breadcrumb li');

            breadcrumbItems.forEach(function(item) {
                // Проверяем, если текст элемента равен "Події"
                if (item.textContent.trim() === 'Події') {
                    // Заменяем текст на "Events"
                    item.textContent = 'Events';
                }
                if (item.textContent.trim() === 'Шаблони проектів') {
                    // Заменяем текст на "Events"
                    item.textContent = 'Project templates';
                }
            });
        }
    </script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            jQuery('a').each(function() {
